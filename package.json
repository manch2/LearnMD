{
  "name": "learnmd",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source framework for creating interactive courses from Markdown files",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:security": "eslint src --ext .ts,.tsx --rule 'security/*: error'",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --audit-level=high",
    "audit:fix": "pnpm audit --audit-level=high --fix",
    "scan": "pnpm run lint && pnpm run audit && pnpm run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "markdown",
    "courses",
    "e-learning",
    "education",
    "react",
    "vite"
  ],
  "license": "MIT"
}
