{
  "name": "learnmd",
  "version": "0.0.3-beta.2",
  "private": true,
  "description": "Open-source framework for creating interactive courses from Markdown files",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:security": "eslint src --ext .ts,.tsx --rule 'security/*: error'",
    "audit": "pnpm audit --audit-level=high",
    "audit:fix": "pnpm audit --audit-level=high --fix",
    "scan": "pnpm run lint && pnpm run audit && pnpm run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:all": "pnpm test && pnpm test:coverage"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.5.1",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "vitest": "^1.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "markdown",
    "courses",
    "e-learning",
    "education",
    "react",
    "vite"
  ],
  "license": "MIT"
}
