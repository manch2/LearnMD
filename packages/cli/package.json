{
  "name": "@learnmd/cli",
  "version": "0.0.3-beta.3",
  "description": "CLI for creating and building LearnMD courses",
  "type": "module",
  "bin": {
    "learnmd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc --watch",
