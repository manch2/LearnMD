    "vite": "^5.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.0",
